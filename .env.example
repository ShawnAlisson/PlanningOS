# Copy this file to .env.local and fill in only what you need.
# PlanningOS works with ZERO configuration (local JSON store, heuristic
# extraction, no LLM) - everything below is optional.

# ------------------------------------------------------------------
# LLM (optional) - used ONLY for project-specific extraction (extension
# type / height / volume from your description or an uploaded drawing).
# Real government constraint data (flood zone, conservation area, green
# belt, Article 4, etc.) NEVER depends on this - it always comes live
# from postcodes.io + planning.data.gov.uk regardless of this section.
#
# Leave all three blank to use the built-in transparent keyword heuristic.
# ------------------------------------------------------------------

# Option A: OpenAI
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# (LLM_BASE_URL not required - defaults to https://api.openai.com/v1)

# Option B: OpenRouter (https://openrouter.ai/keys)
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini

# Option C: Local runtime (Ollama, LM Studio, etc. - any OpenAI-compatible /v1 API)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=ollama   # any non-empty placeholder value works for most local runtimes

# ------------------------------------------------------------------
# Persistence (optional) - without this, PlanningOS uses a local JSON
# file at data/db.json, which is fine for a demo/hackathon run.
# ------------------------------------------------------------------

# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
# MONGODB_DB=planningos

# ------------------------------------------------------------------
# Fetch.ai / ASI:One uAgent bridge (agentverse/planningos_agent.py)
# These are read by the PYTHON agent process, not by Next.js - set them
# in your shell (or agentverse/.env) when running that script, not here.
# ------------------------------------------------------------------

# PLANNINGOS_API_URL=http://localhost:3000       # or your deployed URL
# PLANNINGOS_PUBLIC_URL=http://localhost:3000    # used to build review-page links in chat replies
# PLANNINGOS_AGENT_SEED=change-me-to-a-random-string
# PLANNINGOS_AGENT_PORT=8001

# ------------------------------------------------------------------
# No API key is needed for: postcodes.io, planning.data.gov.uk,
# MapLibre GL JS, or OpenFreeMap map tiles. They are free and public.
# ------------------------------------------------------------------
